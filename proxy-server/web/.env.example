# --- Go admin API (server-side only; never sent to the browser) ---
# Base URL of the local proxy's read-only admin API.
PROXY_ADMIN_BASE_URL=http://127.0.0.1:8787
# Must match the proxy's `admin.auth_token`. Leave empty if the proxy has none.
PROXY_ADMIN_TOKEN=

# --- Admin UI login (ID/PW) ---
# CHANGE THESE before any non-local use.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
# 32+ char random secret used to sign the session cookie. CHANGE THIS.
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
